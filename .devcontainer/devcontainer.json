// For format details, see https://aka.ms/devcontainer.json.
{
    "name": "melange-tracker",
    "workspaceFolder": "/workspaces/melange-tracker",
    "build":  {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": "true",
            "username": "vscode",
            "userUid": "1000",
            "userGid": "1000",
            "upgradePackages": "false"
        },
        "ghcr.io/devcontainers/features/nix:1": {
            "extraNixConfig": "experimental-features = nix-command flakes"
        },
        "./features/ocaml": {
            "version": "5.4.0",
            "packages": "alcotest cmdliner cppo js_of_ocaml menhir merlin ppxlib reason reason-react-ppx odoc"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ocamllabs.ocaml-platform"
            ]
        }
    },
    "remoteUser": "vscode",
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached"
    ],
    "postCreateCommand": {
        "claude": "curl -fsSL https://claude.ai/install.sh | bash",
        "submodules": "git submodule update --init --recursive --depth 1",
        "opam": "sudo sh -ceux \"chown -R $(id -u):$(id -g) ${OPAMROOT}/log\"",
        "upstream": "cd melange && git remote add upstream https://github.com/rescript-lang/rescript.git && git fetch upstream --quiet || true"
    },
    "waitFor": "postCreateCommand"
}
